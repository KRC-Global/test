{
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "Bash(start:*)",
      "Bash(printf \"protocol=https\\\\nhost=github.com\\\\n\")",
      "Bash(git credential-manager:*)",
      "Bash(gh auth:*)"
    ]
  }
}
